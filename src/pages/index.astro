---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdBanner   from '../components/AdBanner.astro';
import BlogCard   from '../components/BlogCard.astro';
import AspLink    from '../components/AspLink.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recommendedItems = [
  {
    title: '標準理学療法学 専門分野 運動療法学（全改訂第5版）',
    description: '国試頻出の運動療法学テキスト。解剖・生理から実践まで網羅。',
    price: '¥5,940',
    badge: '定番',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'クエスチョン・バンク PT国試問題解説（最新版）',
    description: '過去10年分を体系的に解説。受験生に支持される定番問題集。',
    price: '¥6,820',
    badge: 'おすすめ',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'イヤーノート PT・OT（2025年度版）',
    description: '頻出事項を1冊に凝縮。直前期の総まとめに最適。',
    price: '¥3,960',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: '就職・転職支援（PT専門サービス）',
    description: 'PT・OT専門の求人サービス。無料キャリア相談あり。',
    price: '完全無料',
    badge: 'キャリア',
    links: { official: 'https://example.com/pt-career' },
  },
];

// 例題（学習用サンプル問題）
const quizItems = [
  {
    category: '解剖学',
    question: '骨格筋の収縮に直接関わるタンパク質の組み合わせはどれか。',
    answer: 'アクチンとミオシン',
    explanation: 'アクチン（細いフィラメント）とミオシン（太いフィラメント）のクロスブリッジ形成により筋収縮が起こる。トロポニン・トロポミオシンはCa²⁺による調節機構に関与する。',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>`,
  },
  {
    category: '生理学',
    question: '健常成人の安静時心拍数の正常範囲はどれか。',
    answer: '60〜100 回/分',
    explanation: '洞結節の自動能により、安静時の正常心拍数は60〜100 bpm。60未満を徐脈、100超を頻脈と呼ぶ。刺激伝導系（洞→房室→ヒス束→プルキンエ線維）の理解も国試頻出。',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    category: '運動療法',
    question: '最大筋力が最も大きい筋収縮様式はどれか。',
    answer: '遠心性（エキセントリック）収縮',
    explanation: '遠心性収縮は筋が伸張されながら張力を発揮する収縮形態。求心性・等尺性収縮より大きな力が得られ、筋肥大への刺激も最も強い。筋力増強プログラム設計の基礎知識。',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>`,
  },
];
---

<BaseLayout
  title="FLAGSHIP — 理学療法士を目指す学生のコミュニティ"
  description="FLAGSHIPは、データと論理に基づく国試対策とキャリア設計を支援するPT学生コミュニティです。"
>

<!-- ══════════════════════════════════════════
     ローディングアニメーション（SVG Path Tracing）
══════════════════════════════════════════ -->
<div class="loader" id="loader" aria-hidden="true">
  <div class="loader__grid" aria-hidden="true"></div>
  <div class="loader__content">
    <svg class="loader__svg" viewBox="0 0 900 160" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
      <text
        class="loader__text"
        x="50%" y="55%"
        text-anchor="middle"
        dominant-baseline="middle"
        font-size="130"
        font-family="Inter, sans-serif"
        font-weight="900"
        letter-spacing="20"
      >FLAGSHIP</text>
    </svg>
    <p class="loader__sub">PT学生のための学習コミュニティ</p>
  </div>
</div>

<!-- ══════════════════════════════════════════
     ヒーロー
══════════════════════════════════════════ -->
<section class="hero" id="hero">
  <!-- 背景装飾：ドットグリッド + アクセントグロー -->
  <div class="hero__bg-grid" aria-hidden="true"></div>
  <div class="hero__bg-glow" aria-hidden="true"></div>

  <div class="hero__inner container">

    <div class="hero__text">
      <div class="hero__label reveal">
        <span class="hero__label-line"></span>
        PT学生コミュニティ
      </div>

      <h1 class="hero__h1 reveal reveal--delay-1">
        データと論理で、<br>
        <span class="hero__h1-accent">合格</span>を設計する。
      </h1>

      <p class="hero__desc reveal reveal--delay-2">
        感情論・根性論を排除した、<br>
        確実な国試対策プロセスと<br>
        自分軸のキャリア設計を提供する。
      </p>

      <div class="hero__actions reveal reveal--delay-3">
        <a href="#参加" class="btn btn--primary btn--lg">無料で参加する</a>
        <a href="#国試" class="btn btn--ghost btn--lg">国試問題を解く</a>
      </div>
    </div>

    <div class="hero__img-wrap reveal reveal--delay-1">
      <div class="hero__scan-wrap" id="heroScanWrap">
        <div class="hero__img-frame" aria-hidden="true">
          <span class="hero__img-frame-corner hero__img-frame-corner--tl"></span>
          <span class="hero__img-frame-corner hero__img-frame-corner--tr"></span>
          <span class="hero__img-frame-corner hero__img-frame-corner--bl"></span>
          <span class="hero__img-frame-corner hero__img-frame-corner--br"></span>
        </div>
        <img
          src="/images/hero.png"
          alt="FLAGSHIPマスコット"
          class="hero__img"
          width="600"
          height="600"
        />
      </div>
    </div>

  </div>

  <div class="hero__bottom-line">
    <div class="hero__bottom-line-fill"></div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     ブログ（最上位コンテンツ）
══════════════════════════════════════════ -->
<section class="section blog-feature" id="ブログ">
  <div class="container">

    <div class="blog-feature__header reveal">
      <div>
        <span class="section-label">— ブログ</span>
        <h2 class="section-title">最新記事</h2>
      </div>
      <a href="/blog" class="btn btn--outline blog-feature__all-link">
        すべての記事を読む
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="blog-feature__grid">
        <!-- Featured first post -->
        {latestPosts[0] && (
          <a href={`/blog/${latestPosts[0].slug}`} class="blog-feature__lead reveal">
            <div class="blog-feature__lead-img">
              {latestPosts[0].data.heroImage
                ? <img src={latestPosts[0].data.heroImage} alt={latestPosts[0].data.title} />
                : <div class="blog-feature__lead-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
              }
              <span class="blog-feature__new-badge">NEW</span>
            </div>
            <div class="blog-feature__lead-body">
              {latestPosts[0].data.category && (
                <span class="blog-tag">{latestPosts[0].data.category}</span>
              )}
              <h3 class="blog-feature__lead-title">{latestPosts[0].data.title}</h3>
              <p class="blog-feature__lead-desc">{latestPosts[0].data.description}</p>
              <time class="blog-feature__lead-date">
                {latestPosts[0].data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </a>
        )}

        <!-- Sub posts -->
        <div class="blog-feature__sub">
          {latestPosts.slice(1).map((post, i) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              heroImage={post.data.heroImage}
              slug={post.slug}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    ) : (
      <div class="blog-empty reveal">
        <div class="blog-empty__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <p class="blog-empty__title">記事を順次公開中</p>
        <p class="blog-empty__sub">国試対策・キャリア・コミュニティに関する記事を準備しています。</p>
        <a href="/blog" class="btn btn--outline" style="margin-top:1.5rem;">ブログトップへ</a>
      </div>
    )}
  </div>
</section>

<!-- ══════════════════════════════════════════
     PT国試 例題・解説
══════════════════════════════════════════ -->
<section class="section quiz-section" id="国試">
  <div class="quiz-section__bg-grid" aria-hidden="true"></div>
  <div class="container" style="position:relative; z-index:1;">

    <div class="section-header reveal">
      <span class="section-label" style="color:var(--accent);">— PT国試</span>
      <h2 class="section-title" style="color:#fff;">国試例題・解説</h2>
      <p class="section-sub" style="color:rgba(255,255,255,0.55);">
        理解を深める3問。正解と解説で、暗記ではなく「わかる」学習を。
      </p>
    </div>

    <div class="quiz-category-tags reveal">
      {['解剖学', '生理学', '運動療法', '内部障害', '神経障害', '整形外科'].map(tag => (
        <span class="quiz-cat-tag">{tag}</span>
      ))}
    </div>

    <div class="quiz-grid">
      {quizItems.map((q, i) => (
        <div class={`quiz-card reveal${i > 0 ? ' reveal--delay-' + i : ''}`}>
          <div class="quiz-card__header">
            <div class="quiz-card__icon" set:html={q.icon}></div>
            <span class="quiz-card__cat">{q.category}</span>
            <span class="quiz-card__badge">例題</span>
          </div>
          <p class="quiz-card__q">{q.question}</p>
          <div class="quiz-card__answer">
            <div class="quiz-card__answer-label">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              正解
            </div>
            <p class="quiz-card__answer-text">{q.answer}</p>
          </div>
          <details class="quiz-card__details">
            <summary class="quiz-card__details-toggle">解説を読む</summary>
            <p class="quiz-card__exp">{q.explanation}</p>
          </details>
        </div>
      ))}
    </div>

    <div class="quiz-cta reveal">
      <a href="/kokushi" class="btn btn--primary btn--lg quiz-cta__btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        問題データベースを見る
      </a>
      <p class="quiz-cta__note">解剖学・生理学・運動療法・内部障害 etc. 全科目対応予定</p>
    </div>
  </div>
</section>

<!-- 広告枠 -->
<div class="ad-wrap">
  <div class="container">
    <AdBanner size="responsive" />
  </div>
</div>

<!-- ══════════════════════════════════════════
     理念
══════════════════════════════════════════ -->
<section class="section section--alt" id="理念">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 理念</span>
      <h2 class="section-title">FLAGSHIPが目指す世界</h2>
      <p class="section-sub">
        PT学生が孤独に悩まず、論理的に・自信を持って成長できる環境をつくる。
      </p>
    </div>

    <div class="grid-3">
      {[
        {
          num: '01', title: '使命',
          items: ['仲間・情報・機会へのアクセスを提供', 'データと論理に基づく合格プロセスを構築', 'PT業界の担い手となる人材を育成'],
        },
        {
          num: '02', title: '理想',
          items: ['「PTになりたい」という夢を持ち続けられる', '自分の軸を持って社会に羽ばたける', '他者の基準ではなく自己決定できる'],
        },
        {
          num: '03', title: '価値観',
          items: ['本質思考：暗記より理解を重視', '相互成長：与え合うコミュニティ文化', '自己決定：自分の価値観で選択する'],
        },
      ].map((mvv, i) => (
        <div class={`card mvv-card reveal${i > 0 ? ' reveal--delay-' + i : ''}`}>
          <div class="mvv-num">{mvv.num}</div>
          <h3 class="mvv-title">{mvv.title}</h3>
          <div class="accent-line"></div>
          <ul class="value-list">
            {mvv.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     合格者に選ばれた教材
══════════════════════════════════════════ -->
<section class="section" id="教材">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 学習ガイド</span>
      <h2 class="section-title">合格者が選んだ教材</h2>
      <p class="section-sub">
        FLAGSHIPメンバーが実際に使い、効果を実感した教材・サービスをご紹介します。
      </p>
    </div>

    <div class="grid-4" style="margin-top: 2rem;">
      {recommendedItems.map(item => (
        <AspLink
          title={item.title}
          description={item.description}
          price={item.price}
          badge={item.badge}
          links={item.links}
        />
      ))}
    </div>
  </div>
</section>

<!-- 広告枠 -->
<div class="ad-wrap">
  <div class="container">
    <AdBanner size="responsive" />
  </div>
</div>

<!-- ══════════════════════════════════════════
     参加CTA
══════════════════════════════════════════ -->
<section class="section section--dark" id="参加">
  <div class="container cta-inner">
    <div class="cta-watermark" aria-hidden="true">FLAGSHIP</div>

    <div class="cta-content reveal">
      <span class="section-label" style="color: var(--accent);">— 参加</span>
      <h2 class="cta-title">
        仲間と、<span class="cta-accent">論理的に</span>合格を目指す。
      </h2>
      <p class="cta-desc">
        参加は完全無料。PT学生であれば、学年・地域を問わずどなたでも。
      </p>

      <div class="cta-actions">
        <a href="https://join.slack.com/placeholder" target="_blank" rel="noopener"
           class="btn btn--primary btn--lg">
          Slackで無料参加
        </a>
        <a href="/about" class="btn btn--ghost btn--lg" style="border-color:rgba(255,255,255,0.2); color:#fff;">
          FLAGSHIPとは
        </a>
      </div>

      <p class="cta-note">
        登録費用なし　｜　メールアドレス不要　｜　いつでも退会可能
      </p>
    </div>
  </div>
</section>

</BaseLayout>

<!-- ══ STYLES ══ -->
<style>
/* ── LOADER ──────────────────────────── */
.loader {
  position: fixed; inset: 0;
  background: #FCFCFC;
  display: flex; align-items: center; justify-content: center;
  z-index: 9999; pointer-events: none;
}
.loader__grid {
  position: absolute; inset: 0;
  opacity: 0.04; pointer-events: none;
  background-image:
    linear-gradient(to right, #2B3A55 1px, transparent 1px),
    linear-gradient(to bottom, #2B3A55 1px, transparent 1px);
  background-size: 36px 36px;
}
.loader__content {
  display: flex; flex-direction: column; align-items: center; gap: 1.25rem;
  position: relative; z-index: 1;
}
.loader__svg {
  width: min(860px, 92vw);
  overflow: visible;
  display: block;
}
.loader__text {
  fill: transparent;
  stroke: #2B3A55; stroke-width: 2;
  stroke-dasharray: 5500; stroke-dashoffset: 5500;
  animation:
    drawStroke  1.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards,
    fillText    0.5s ease-in 1.7s forwards,
    fadeStroke  0.5s ease-in 1.7s forwards;
}
.loader__sub {
  font-size: clamp(0.7rem, 3vw, 0.85rem);
  font-family: 'Noto Sans JP', sans-serif;
  font-weight: 500;
  letter-spacing: 0.2em;
  color: var(--text-mid);
  opacity: 0;
  animation: fadeInSub 0.5s ease-out 1.8s forwards;
}
@keyframes drawStroke { to { stroke-dashoffset: 0; } }
@keyframes fillText   { to { fill: #2B3A55; } }
@keyframes fadeStroke { to { stroke: transparent; } }
@keyframes fadeInSub  { to { opacity: 1; } }
.loader.hide { animation: loaderOut 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
@keyframes loaderOut  { to { opacity: 0; transform: translateY(-6px); } }

/* ── HERO ────────────────────────────── */
.hero {
  background: var(--bg);
  border-bottom: 1px solid var(--border-light);
  position: relative;
  overflow: hidden;
}

/* Dot grid background */
.hero__bg-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image: radial-gradient(circle, rgba(43,58,85,0.07) 1px, transparent 1px);
  background-size: 24px 24px;
}

/* Accent glow */
.hero__bg-glow {
  position: absolute;
  top: -20%; right: -10%;
  width: 60%; height: 80%;
  background: radial-gradient(ellipse, rgba(0,168,255,0.07) 0%, transparent 65%);
  pointer-events: none;
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
  padding-top: 88px;
  padding-bottom: 88px;
  min-height: 88vh;
  position: relative; z-index: 1;
}

.hero__label {
  display: flex; align-items: center; gap: 0.75rem;
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.16em; color: var(--text-mid);
  margin-bottom: 1.5rem;
}
.hero__label-line {
  display: block; width: 24px; height: 1.5px;
  background: var(--accent);
}
.hero__h1 {
  font-size: clamp(2.2rem, 4.5vw, 3.5rem);
  font-weight: 900; line-height: 1.2;
  letter-spacing: -0.02em; color: var(--text);
  margin-bottom: 1.5rem;
}
.hero__h1-accent { color: var(--accent); }
.hero__desc {
  font-size: 1rem; color: var(--text-body);
  line-height: 1.9; margin-bottom: 2.5rem;
}
.hero__actions {
  display: flex; gap: 1rem;
  flex-wrap: wrap;
}

/* Hero image with tech-frame corners */
.hero__img-wrap { position: relative; }
.hero__scan-wrap { position: relative; overflow: hidden; }

.hero__img-frame {
  position: absolute; inset: -8px; z-index: 2; pointer-events: none;
}
.hero__img-frame-corner {
  position: absolute; width: 16px; height: 16px;
  border-color: var(--accent); border-style: solid;
  opacity: 0.6;
}
.hero__img-frame-corner--tl { top: 0; left: 0; border-width: 1.5px 0 0 1.5px; }
.hero__img-frame-corner--tr { top: 0; right: 0; border-width: 1.5px 1.5px 0 0; }
.hero__img-frame-corner--bl { bottom: 0; left: 0; border-width: 0 0 1.5px 1.5px; }
.hero__img-frame-corner--br { bottom: 0; right: 0; border-width: 0 1.5px 1.5px 0; }

.hero__img {
  width: 100%; height: auto;
  object-fit: contain;
  filter: drop-shadow(0 24px 64px rgba(0,0,0,0.10));
  display: block;
}

/* Scan reveal */
.effect-scan-reveal img {
  filter: blur(20px) grayscale(100%) contrast(140%);
  animation: resolveHero 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.effect-scan-reveal::after {
  content: ''; position: absolute;
  top: -100%; left: 0; right: 0; height: 100%;
  background: linear-gradient(to bottom, transparent, rgba(0,168,255,0.15) 50%, rgba(0,168,255,0.65) 100%);
  animation: scanDownHero 1.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
