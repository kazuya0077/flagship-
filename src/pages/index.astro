---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdBanner   from '../components/AdBanner.astro';
import BlogCard   from '../components/BlogCard.astro';
import AspLink    from '../components/AspLink.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// ── ASP商品データ ──────────────────────────────
// ※ リンクを実際のアフィリエイトURLに差し替えてください
const aspProducts = [
  {
    title: '標準理学療法学 専門分野 運動療法学（全改訂第5版）',
    description: '国試頻出の運動療法学テキスト。解剖・生理から実践まで網羅した定番の一冊。',
    price: '¥5,940（税込）',
    badge: 'おすすめ',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_AMAZON_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'イヤーノート PT・OT（2025年度版）',
    description: 'PT・OT国試の頻出事項を1冊に凝縮。直前の総まとめに最適なポケットサイズ参考書。',
    price: '¥3,960（税込）',
    badge: '定番',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_AMAZON_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'クエスチョン・バンク PT国試問題解説（最新版）',
    description: '過去10年分の国試問題を体系的に解説。解説の質が高く、毎年受験生に支持される定番問題集。',
    price: '¥6,820（税込）',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_AMAZON_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'PT転職ナビ（PT専門求人サービス）',
    description: 'PT・OT専門の転職・就活支援サービス。非公開求人多数、無料キャリア相談あり。',
    price: '完全無料',
    badge: 'キャリア',
    links: {
      official: 'https://example.com/pt-tenshoku',
    },
  },
];
---

<BaseLayout
  title="FLAGSHIP — 理学療法士を目指す学生のコミュニティ"
  description="FLAGSHIPは理学療法士を目指す学生のための学習・キャリアコミュニティ。国試対策から就活まで、仲間と一緒に成長しよう。"
>

<!-- ══════════════════════════════════════════════════════
     SECTION 1 — HERO
     ・画像は /public/images/hero.jpg に配置してください
     ・右カラムの <img> src を差し替えるだけでOKです
══════════════════════════════════════════════════════ -->
<section class="hero-section">
  <div class="hero-inner container">

    <!-- Left: テキスト -->
    <div class="hero-text">
      <span class="section-label" style="margin-bottom: 1.25rem;">PT Student Community</span>
      <h1 class="hero-h1">
        自分の軸で、<br>
        PTになれ。
      </h1>
      <p class="hero-desc">
        理学療法士を目指すすべての学生へ。<br>
        国試対策・キャリア設計・先輩との繋がり——<br>
        FLAGSHIPが、あなたの成長を支える。
      </p>
      <div class="hero-actions">
        <a href="#join" class="btn btn--primary btn--lg">無料でコミュニティに参加</a>
        <a href="#services" class="btn btn--outline btn--lg">サービスを見る</a>
      </div>
      <p style="margin-top: 1.25rem; font-size: 0.78rem; color: var(--text-dim);">
        ✓ 完全無料 &nbsp; ✓ PT学生ならどなたでも &nbsp; ✓ 全国のPT学生が参加中
      </p>
    </div>

    <!-- Right: ヒーロー画像 -->
    <!-- ★ここに画像を置いてください: /public/images/hero.jpg -->
    <div class="hero-img-wrap">
      <img
        src="/images/hero.jpg"
        alt="理学療法士を目指す学生のコミュニティ FLAGSHIP"
        class="hero-img"
        onerror="this.parentElement.classList.add('hero-img-wrap--fallback'); this.style.display='none';"
      />
      <!-- 画像がない場合のフォールバック -->
      <div class="hero-img-fallback" aria-hidden="true">
        <div class="hero-img-fallback__inner">
          <svg viewBox="0 0 200 200" width="120" height="120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="100" cy="80" r="35" stroke="var(--accent)" stroke-width="3"/>
            <path d="M50 180 Q100 130 150 180" stroke="var(--accent)" stroke-width="3" fill="none"/>
            <path d="M80 115 L80 155 M120 115 L120 155" stroke="var(--accent)" stroke-width="2.5"/>
            <path d="M65 145 L80 155 L95 145" stroke="var(--accent)" stroke-width="2" fill="none"/>
            <path d="M105 145 L120 155 L135 145" stroke="var(--accent)" stroke-width="2" fill="none"/>
          </svg>
          <p style="font-family:'Inter',sans-serif; font-weight:700; font-size:0.8rem; color:var(--text-dim); letter-spacing:0.08em; margin-top:1rem;">
            HERO IMAGE
          </p>
          <p style="font-size:0.72rem; color:var(--text-dim);">/public/images/hero.jpg</p>
        </div>
      </div>
    </div>

  </div>

  <!-- 下部アクセントライン -->
  <div style="height: 3px; background: linear-gradient(90deg, var(--accent) 0%, transparent 100%);"></div>
</section>

<!-- ══════════════════════════════════════════════════════
     SECTION 2 — MVV (Mission / Vision / Values)
══════════════════════════════════════════════════════ -->
<section class="section section--alt" id="about">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Our Purpose</span>
      <h2 class="section-title">FLAGSHIPが目指す世界</h2>
      <p class="section-sub">
        PT学生が孤独に悩まず、自信を持って成長できる環境をつくる。
      </p>
    </div>

    <div class="grid-3" style="margin-top: 3rem;">
      <div class="card target-card reveal">
        <div class="mvv-num">01</div>
        <h3 class="mvv-title">Mission</h3>
        <div class="accent-line"></div>
        <p>
          理学療法士を目指す学生が、<strong>仲間・情報・機会</strong>にアクセスできるプラットフォームを提供し、
          PT業界の担い手となる人材を育てる。
        </p>
      </div>
      <div class="card target-card reveal reveal--delay-1">
        <div class="mvv-num">02</div>
        <h3 class="mvv-title">Vision</h3>
        <div class="accent-line"></div>
        <p>
          「PTになりたい」という夢を持つすべての学生が、<strong>自分の軸を持って</strong>
          社会に羽ばたける世界をつくる。
        </p>
      </div>
      <div class="card target-card reveal reveal--delay-2">
        <div class="mvv-num">03</div>
        <h3 class="mvv-title">Values</h3>
        <div class="accent-line"></div>
        <p>
          <strong>本質思考</strong>：予備校的な暗記ではなく、理解を重視する。<br>
          <strong>相互成長</strong>：与え合うコミュニティ文化を大切にする。<br>
          <strong>自己決定</strong>：他者の基準ではなく、自分の価値観で選ぶ。
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     SECTION 3 — SERVICES
══════════════════════════════════════════════════════ -->
<section class="section" id="services">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Services</span>
      <h2 class="section-title">FLAGSHIPの2つのサポート</h2>
      <p class="section-sub">
        入学直後から卒業後まで、PTとしての成長を多角的に支援します。
      </p>
    </div>

    <div class="grid-2" style="gap: 2rem; margin-top: 3rem;">
      <!-- Track 1 -->
      <div class="service-card reveal">
        <div class="service-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <h3 class="service-card__title">国試・学業サポート</h3>
        <div class="accent-line"></div>
        <ul class="service-list">
          <li>先輩PTによる科目別解説コンテンツ</li>
          <li>週次オンライン勉強会（Zoom）</li>
          <li>過去問・弱点チェックツール</li>
          <li>スタディグループのマッチング</li>
          <li>国試直前集中プログラム</li>
        </ul>
        <a href="/resources" class="btn btn--outline" style="margin-top: 1.5rem;">
          学習素材を見る →
        </a>
      </div>

      <!-- Track 2 -->
      <div class="service-card reveal reveal--delay-1">
        <div class="service-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <h3 class="service-card__title">キャリア・価値観形成</h3>
        <div class="accent-line"></div>
        <ul class="service-list">
          <li>現役PTメンターとの1on1セッション</li>
          <li>キャリアパス別ロードマップ</li>
          <li>先輩PTの就活・転職体験談</li>
          <li>実習対策・OSCE準備サポート</li>
          <li>自己分析ワークショップ</li>
        </ul>
        <a href="/for-schools" class="btn btn--outline" style="margin-top: 1.5rem;">
          詳しく見る →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     SECTION 4 — ASP（おすすめ教材・サービス）
     ※ aspProducts 配列のリンクを実際のAFリンクに差し替えてください
══════════════════════════════════════════════════════ -->
<section class="section section--alt" id="recommend">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Recommend <span class="ad-label" style="margin-left:0.5rem;">PR</span></span>
      <h2 class="section-title">おすすめ教材・サービス</h2>
      <p class="section-sub">
        FLAGSHIP編集部がPT学生に本当に役立つと判断した教材・サービスをご紹介します。
      </p>
    </div>

    <div class="grid-4" style="margin-top: 3rem;">
      {aspProducts.map(p => (
        <AspLink
          title={p.title}
          description={p.description}
          price={p.price}
          badge={p.badge}
          links={p.links}
        />
      ))}
    </div>

    <p style="text-align:center; font-size:0.75rem; color:var(--text-dim); margin-top:1.5rem;">
      ※ 上記リンクはアフィリエイトリンクを含む場合があります。
    </p>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     BANNER AD — レスポンシブ広告枠
     ※ adCode プロパティにGoogle AdSenseコードを貼り付け
══════════════════════════════════════════════════════ -->
<div style="background: var(--bg); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
  <div class="container">
    <AdBanner size="responsive" />
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     SECTION 5 — BLOG PREVIEW
══════════════════════════════════════════════════════ -->
<section class="section" id="blog">
  <div class="container">
    <div class="section-header reveal" style="display:flex; justify-content:space-between; align-items:flex-end; text-align:left; margin-bottom:2.5rem;">
      <div>
        <span class="section-label">Blog</span>
        <h2 class="section-title" style="margin-bottom:0;">最新記事</h2>
      </div>
      <a href="/blog" class="btn btn--outline" style="flex-shrink:0;">すべて見る →</a>
    </div>

    <div class="grid-3">
      {latestPosts.map((post, i) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          heroImage={post.data.heroImage}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </div>

    {latestPosts.length === 0 && (
      <p style="text-align:center; color:var(--text-dim); padding:3rem 0;">
        記事を準備中です。しばらくお待ちください。
      </p>
    )}
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     SECTION 6 — COMMUNITY FEATURES
══════════════════════════════════════════════════════ -->
<section class="section section--alt" id="community">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Community</span>
      <h2 class="section-title">コミュニティの特徴</h2>
      <p class="section-sub">
        FLAGSHIPは、入学直後の1年生から国試直前の4年生まで、すべてのPT学生を歓迎します。
      </p>
    </div>

    <div class="grid-4" style="margin-top: 3rem;">
      <div class="feature-item reveal">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <h4 class="feature-title">学習メソッド</h4>
        <p class="feature-desc">
          予備校的な丸暗記ではなく、「なぜ？」を大切にした本質理解型の学習を仲間と実践。
        </p>
      </div>

      <div class="feature-item reveal reveal--delay-1">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h4 class="feature-title">相互サポート</h4>
        <p class="feature-desc">
          わからないことを気軽に質問できる雰囲気。先輩・同期・後輩が一緒に高め合う場所。
        </p>
      </div>

      <div class="feature-item reveal reveal--delay-2">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h4 class="feature-title">キャリア設計</h4>
        <p class="feature-desc">
          「なんとなく病院へ」ではなく、自分の価値観に基づいたキャリア選択を先輩PTと一緒に考える。
        </p>
      </div>

      <div class="feature-item reveal reveal--delay-3">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h4 class="feature-title">先輩ネットワーク</h4>
        <p class="feature-desc">
          全国の現役PTや実習経験者との繋がりで、リアルな現場情報や就活のリアルを知れる。
        </p>
      </div>
    </div>

    <!-- Purpose quote -->
    <blockquote class="purpose-quote reveal" style="margin-top: 4rem;">
      <p>
        「PTになりたい」という夢は、入学した瞬間が一番輝いている。<br>
        FLAGSHIPは、その輝きを卒業まで持ち続けるための場所です。
      </p>
      <footer>— FLAGSHIP 運営チーム</footer>
    </blockquote>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     SECTION 7 — CTA（参加）
══════════════════════════════════════════════════════ -->
<section class="section section--dark" id="join">
  <div class="container" style="text-align: center; position: relative; overflow: hidden;">

    <!-- 背景ウォーターマーク -->
    <div class="cta-watermark" aria-hidden="true">FLAGSHIP</div>

    <div style="position: relative; z-index: 1;">
      <span class="section-label" style="color: var(--accent);">Join Us</span>
      <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); color: #fff; margin-bottom: 1.25rem;">
        さあ、<span style="color: var(--accent);">仲間</span>と成長しよう。
      </h2>
      <p style="font-size: 1.05rem; color: #8a9ab5; max-width: 520px; margin: 0 auto 2.5rem; line-height: 1.8;">
        FLAGSHIPへの参加は完全無料。<br>
        PT学生であれば、学年・地域を問わずどなたでも参加できます。
      </p>

      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://join.slack.com/placeholder" target="_blank" rel="noopener"
           class="btn btn--primary btn--lg">
          Slackで無料参加する
        </a>
        <a href="/about" class="btn btn--outline btn--lg" style="border-color: rgba(255,255,255,0.3); color: #fff;">
          FLAGSHIPとは？
        </a>
      </div>

      <p style="margin-top: 2rem; font-size: 0.78rem; color: #5a6a80;">
        ✓ 登録費用なし &nbsp;｜&nbsp; ✓ メールアドレス不要 &nbsp;｜&nbsp; ✓ いつでも退会可能
      </p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* ── HERO ─────────────────────────── */
.hero-section {
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  padding-top: 80px;
  padding-bottom: 80px;
  min-height: 85vh;
}

.hero-text { }

.hero-h1 {
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1.15;
  margin-bottom: 1.5rem;
  letter-spacing: -0.01em;
}

.hero-desc {
  font-size: 1.05rem;
  color: var(--text-mid);
  line-height: 1.85;
  margin-bottom: 2rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* Hero image */
.hero-img-wrap {
  position: relative;
  border-radius: 0;
  overflow: hidden;
  aspect-ratio: 4/3;
  background: var(--bg-alt);
  border: 1px solid var(--border);
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.hero-img-fallback {
  display: none;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f4f8 0%, #dde3ea 100%);
}

/* Show fallback when image errors */
.hero-img-wrap--fallback .hero-img-fallback {
  display: flex;
}

.hero-img-fallback__inner {
  text-align: center;
}

/* ── MVV ─────────────────────────── */
.mvv-num {
  font-family: 'Inter', sans-serif;
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--accent);
  opacity: 0.25;
  line-height: 1;
  margin-bottom: 0.25rem;
}

.mvv-title {
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

/* ── SERVICE CARD ─────────────────── */
.service-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 2.5rem;
  box-shadow: var(--shadow);
}

.service-card__icon {
  width: 56px;
  height: 56px;
  background: var(--accent-dim);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
}

.service-card__title {
  font-size: 1.25rem;
  margin-bottom: 1rem;
}

.service-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.service-list li {
  font-size: 0.9rem;
  color: var(--text-body);
  padding-left: 1.25rem;
  position: relative;
}

.service-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 6px;
  height: 6px;
  background: var(--accent);
  border-radius: 50%;
}

/* ── FEATURES ─────────────────────── */
.feature-item {
  text-align: center;
  padding: 2rem 1.5rem;
}

.feature-icon {
  width: 60px;
  height: 60px;
  background: var(--accent-dim);
  border: 1px solid var(--border-acc);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
}

.feature-title {
  font-size: 1rem;
  margin-bottom: 0.75rem;
  letter-spacing: 0.04em;
}

.feature-desc {
  font-size: 0.875rem;
  color: var(--text-mid);
  line-height: 1.7;
}

/* ── PURPOSE QUOTE ────────────────── */
.purpose-quote {
  border-left: 3px solid var(--accent);
  padding: 1.75rem 2rem;
  background: var(--bg-card);
  max-width: 640px;
  margin: 0 auto;
  box-shadow: var(--shadow);
}

.purpose-quote p {
  font-size: 1.05rem;
  color: var(--text);
