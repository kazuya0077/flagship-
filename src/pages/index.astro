<script>
  // ─── ローダーを非表示にし、ヒーロー画像のスキャン演出を起動 ───
  window.addEventListener('load', () => {
    setTimeout(() => {
      const loader = document.getElementById('loader');
      if (loader) {
        loader.classList.add('hide');
        setTimeout(() => {
          loader.remove();
          // ローダー退場後にヒーロー画像スキャンリビールを起動
          const scanWrap = document.getElementById('heroScanWrap');
          if (scanWrap) scanWrap.classList.add('effect-scan-reveal');
        }, 700);
      }
    }, 2600);
  });
</script>
