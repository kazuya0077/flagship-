---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdBanner   from '../components/AdBanner.astro';
import BlogCard   from '../components/BlogCard.astro';
import AspLink    from '../components/AspLink.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// ── 合格者に選ばれた教材（ステルスで自然に溶け込む形で掲載）
// ※ リンクはアフィリエイトURLに差し替えてください
const recommendedItems = [
  {
    title: '標準理学療法学 専門分野 運動療法学（全改訂第5版）',
    description: '国試頻出の運動療法学テキスト。解剖・生理から実践まで網羅。毎年の合格者が口を揃えておすすめする一冊。',
    price: '¥5,940',
    badge: '定番',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'クエスチョン・バンク PT国試問題解説（最新版）',
    description: '過去10年分を体系的に解説。解説の精度が高く、毎年受験生に支持される定番問題集。',
    price: '¥6,820',
    badge: 'おすすめ',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: 'イヤーノート PT・OT（2025年度版）',
    description: '頻出事項を1冊に凝縮。直前期の総まとめとして最適なポケットサイズ参考書。',
    price: '¥3,960',
    links: {
      amazon:  'https://www.amazon.co.jp/dp/xxxxxxxx?tag=YOUR_TAG',
      rakuten: 'https://item.rakuten.co.jp/xxx',
    },
  },
  {
    title: '就職・転職支援（PT専門サービス）',
    description: 'PT・OT専門の求人サービス。非公開求人多数、無料キャリア相談あり。卒業後のキャリア設計に。',
    price: '完全無料',
    badge: 'キャリア',
    links: { official: 'https://example.com/pt-career' },
  },
];
---

<BaseLayout
  title="FLAGSHIP — 理学療法士を目指す学生のコミュニティ"
  description="FLAGSHIPは、データと論理に基づく国試対策とキャリア設計を支援するPT学生コミュニティです。"
>

<!-- ══════════════════════════════════════════
     ローディングアニメーション（SVG Path Tracing）
══════════════════════════════════════════ -->
<div class="loader" id="loader" aria-hidden="true">
  <div class="loader__grid" aria-hidden="true"></div>
  <svg class="loader__svg" viewBox="0 0 1000 180" xmlns="http://www.w3.org/2000/svg">
    <text
      class="loader__text"
      x="50%" y="50%"
      text-anchor="middle"
      dominant-baseline="middle"
    >FLAGSHIP</text>
  </svg>
</div>

<!-- ══════════════════════════════════════════
     ヒーローセクション
══════════════════════════════════════════ -->
<section class="hero" id="hero">
  <div class="hero__inner container">

    <!-- 左：テキスト -->
    <div class="hero__text">
      <div class="hero__label reveal">
        <span class="hero__label-line"></span>
        PT学生コミュニティ
      </div>

      <h1 class="hero__h1 reveal reveal--delay-1">
        データと論理で、<br>
        <span class="hero__h1-accent">合格</span>を設計する。
      </h1>

      <p class="hero__desc reveal reveal--delay-2">
        感情論・根性論を排除した、<br>
        確実な国試対策プロセスと<br>
        自分軸のキャリア設計を提供する。
      </p>

      <div class="hero__actions reveal reveal--delay-3">
        <a href="#参加" class="btn btn--primary btn--lg">無料で参加する</a>
        <a href="#機能" class="btn btn--ghost btn--lg">詳しく見る</a>
      </div>

      <!-- 数値実績 -->
      <div class="hero__stats reveal reveal--delay-3">
        <div class="hero__stat">
          <span class="stat-num">300<span style="font-size:0.6em">+</span></span>
          <span class="stat-label">参加学生数</span>
        </div>
        <div class="hero__stat-div"></div>
        <div class="hero__stat">
          <span class="stat-num">92<span style="font-size:0.6em">%</span></span>
          <span class="stat-label">合格率</span>
        </div>
        <div class="hero__stat-div"></div>
        <div class="hero__stat">
          <span class="stat-num">無料</span>
          <span class="stat-label">参加費用</span>
        </div>
      </div>
    </div>

    <!-- 右：マスコット画像 -->
    <div class="hero__img-wrap reveal reveal--delay-1">
      <div class="hero__scan-wrap" id="heroScanWrap">
        <img
          src="/images/hero.png"
          alt="FLAGSHIPマスコット"
          class="hero__img"
          width="600"
          height="450"
        />
      </div>
    </div>

  </div>

  <!-- 区切りライン -->
  <div class="hero__bottom-line">
    <div class="hero__bottom-line-fill"></div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     理念（MVV）
══════════════════════════════════════════ -->
<section class="section section--alt" id="理念">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 理念</span>
      <h2 class="section-title">FLAGSHIPが目指す世界</h2>
      <p class="section-sub">
        PT学生が孤独に悩まず、論理的に・自信を持って成長できる環境をつくる。
      </p>
    </div>

    <div class="grid-3">
      <div class="card reveal">
        <div class="mvv-num">01</div>
        <h3 class="mvv-title">使命</h3>
        <div class="accent-line"></div>
        <ul class="value-list">
          <li>仲間・情報・機会へのアクセスを提供</li>
          <li>データと論理に基づく合格プロセスを構築</li>
          <li>PT業界の担い手となる人材を育成</li>
        </ul>
      </div>

      <div class="card reveal reveal--delay-1">
        <div class="mvv-num">02</div>
        <h3 class="mvv-title">理想</h3>
        <div class="accent-line"></div>
        <ul class="value-list">
          <li>「PTになりたい」という夢を持ち続けられる</li>
          <li>自分の軸を持って社会に羽ばたける</li>
          <li>他者の基準ではなく自己決定できる</li>
        </ul>
      </div>

      <div class="card reveal reveal--delay-2">
        <div class="mvv-num">03</div>
        <h3 class="mvv-title">価値観</h3>
        <div class="accent-line"></div>
        <ul class="value-list">
          <li><strong>本質思考</strong>：暗記より理解を重視</li>
          <li><strong>相互成長</strong>：与え合うコミュニティ文化</li>
          <li><strong>自己決定</strong>：自分の価値観で選択する</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     機能・サービス
══════════════════════════════════════════ -->
<section class="section" id="機能">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 機能</span>
      <h2 class="section-title">2つの柱で成長を支援</h2>
      <p class="section-sub">
        入学直後から卒業後まで、PTとしての成長を多角的にサポート。
      </p>
    </div>

    <div class="grid-2" style="gap: 2rem;">
      <div class="service-panel reveal">
        <div class="service-panel__tag">国試・学業</div>
        <h3 class="service-panel__title">確実な合格プロセス</h3>
        <p class="service-panel__desc">
          感情論を排除した、データに基づく学習戦略。
        </p>
        <ul class="feature-list">
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            先輩PTによる科目別解説コンテンツ
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            週次オンライン勉強会（Zoom）
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            弱点分析・過去問データベース
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            スタディグループのマッチング
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            国試直前集中プログラム
          </li>
        </ul>
        <a href="/resources" class="btn btn--outline" style="margin-top: 1.5rem;">学習素材を見る</a>
      </div>

      <div class="service-panel reveal reveal--delay-1">
        <div class="service-panel__tag">キャリア</div>
        <h3 class="service-panel__title">自分軸のキャリア設計</h3>
        <p class="service-panel__desc">
          「なんとなく病院へ」ではなく、論理的に選ぶ。
        </p>
        <ul class="feature-list">
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            現役PTメンターとの1on1セッション
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            キャリアパス別ロードマップ
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            先輩PTの就活・転職体験談
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            実習対策・OSCE準備サポート
          </li>
          <li>
            <span class="feature-list__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            自己分析ワークショップ
          </li>
        </ul>
        <a href="/about" class="btn btn--outline" style="margin-top: 1.5rem;">詳しく見る</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     合格者に選ばれた教材（ステルス掲載）
     ※「ASP」「PR」「広告」の文字は一切不使用
══════════════════════════════════════════ -->
<section class="section section--alt" id="教材">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 学習ガイド</span>
      <h2 class="section-title">合格者が選んだ教材</h2>
      <p class="section-sub">
        FLAGSHIPメンバーが実際に使い、効果を実感した教材・サービスをご紹介します。
      </p>
    </div>

    <div class="grid-4" style="margin-top: 2rem;">
      {recommendedItems.map(item => (
        <AspLink
          title={item.title}
          description={item.description}
          price={item.price}
          badge={item.badge}
          links={item.links}
        />
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     広告枠（AdSense / 直接広告）
══════════════════════════════════════════ -->
<div style="border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
  <div class="container">
    <AdBanner size="responsive" />
  </div>
</div>

<!-- ══════════════════════════════════════════
     最新ブログ記事
══════════════════════════════════════════ -->
<section class="section" id="ブログ">
  <div class="container">
    <div class="section-header reveal" style="display:flex; justify-content:space-between; align-items:flex-end;">
      <div>
        <span class="section-label">— ブログ</span>
        <h2 class="section-title" style="margin-bottom:0;">最新の投稿</h2>
      </div>
      <a href="/blog" class="btn btn--ghost" style="flex-shrink:0;">すべて見る</a>
    </div>

    <div class="grid-3">
      {latestPosts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          heroImage={post.data.heroImage}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </div>

    {latestPosts.length === 0 && (
      <p style="text-align:center; color:var(--text-dim); padding:3rem 0;">記事を準備中です。</p>
    )}
  </div>
</section>

<!-- ══════════════════════════════════════════
     コミュニティの特徴
══════════════════════════════════════════ -->
<section class="section section--alt" id="コミュニティ">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="section-label">— コミュニティ</span>
      <h2 class="section-title">全国のPT学生と繋がる</h2>
      <p class="section-sub">
        入学直後の1年生から国試直前の4年生まで、学年・地域を問わず参加できます。
      </p>
    </div>

    <div class="grid-4" style="margin-top: 3rem;">
      {[
        {
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
          title: '本質理解型の学習',
          desc: '暗記に頼らず「なぜ？」を起点とした深い理解を、仲間と共に実践。',
        },
        {
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
          title: '気軽な相互サポート',
          desc: 'わからないことを気軽に質問できる雰囲気。先輩・同期・後輩が一緒に高め合う。',
        },
        {
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
          title: '自分軸のキャリア選択',
          desc: '先輩PTと一緒に、価値観に基づいたキャリア選択をじっくり考える機会。',
        },
        {
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
          title: '先輩PTのリアルな声',
          desc: '全国の現役PTから、就活・臨床・働き方のリアルな情報を直接聞ける。',
        },
      ].map((item, i) => (
        <div class={`feature-block card reveal${i > 0 ? ' reveal--delay-' + i : ''}`}>
          <div class="feature-block__icon" set:html={item.icon}></div>
          <h4 class="feature-block__title">{item.title}</h4>
          <p class="feature-block__desc">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- 引用 -->
    <blockquote class="purpose-quote reveal" style="margin-top: 4rem;">
      <p>
        「PTになりたい」という夢は、入学した瞬間が一番輝いている。<br>
        FLAGSHIPは、その輝きを卒業まで持ち続けるための場所です。
      </p>
      <footer>— FLAGSHIP 運営チーム</footer>
    </blockquote>
  </div>
</section>

<!-- ══════════════════════════════════════════
     参加CTA
══════════════════════════════════════════ -->
<section class="section section--dark" id="参加">
  <div class="container cta-inner">
    <div class="cta-watermark" aria-hidden="true">FLAGSHIP</div>

    <div class="cta-content reveal">
      <span class="section-label" style="color: var(--accent);">— 参加</span>
      <h2 class="cta-title">
        仲間と、<span class="cta-accent">論理的に</span>合格を目指す。
      </h2>
      <p class="cta-desc">
        参加は完全無料。PT学生であれば、学年・地域を問わずどなたでも。
      </p>

      <div class="cta-actions">
        <a href="https://join.slack.com/placeholder" target="_blank" rel="noopener"
           class="btn btn--primary btn--lg">
          Slackで無料参加
        </a>
        <a href="/about" class="btn btn--ghost btn--lg" style="border-color:rgba(255,255,255,0.2); color:#fff;">
          FLAGSHIPとは
        </a>
      </div>

      <p class="cta-note">
        登録費用なし　｜　メールアドレス不要　｜　いつでも退会可能
      </p>
    </div>
  </div>
</section>

</BaseLayout>

<!-- ══ LOADING ANIMATION ══ -->
<style>
/* ── LOADER ──────────────────────────── */
.loader {
  position: fixed;
  inset: 0;
  background: #FCFCFC;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  pointer-events: none;
}

/* 背景グリッド装飾 */
.loader__grid {
  position: absolute;
  inset: 0;
  opacity: 0.035;
  pointer-events: none;
  background-image:
    linear-gradient(to right, #000 1px, transparent 1px),
    linear-gradient(to bottom, #000 1px, transparent 1px);
  background-size: 40px 40px;
}

.loader__svg { width: min(900px, 88vw); overflow: visible; }

/* SVGテキストのスタイルはCSSクラスで制御（レスポンシブ対応） */
.loader__text {
  font-family: 'Inter', sans-serif;
  font-weight: 900;
  font-size: clamp(3.5rem, 9vw, 6.5rem);
  letter-spacing: 0.18em;
  fill: transparent;
  stroke: #2B3A55;
  stroke-width: 1.5;
  stroke-dasharray: 4000;
  stroke-dashoffset: 4000;
  animation:
    drawStroke  1.5s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards,
    fillText    0.6s ease-in 1.7s forwards,
    fadeStroke  0.6s ease-in 1.7s forwards;
}

@keyframes drawStroke {
  to { stroke-dashoffset: 0; }
}

@keyframes fillText {
  to { fill: #2B3A55; }
}

@keyframes fadeStroke {
  to { stroke: transparent; }
}

.loader.hide {
  animation: loaderOut 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes loaderOut {
  to { opacity: 0; transform: translateY(-100%); }
}

/* ── HERO IMAGE SCAN WRAP ─────────────── */
.hero__scan-wrap {
  position: relative;
  overflow: hidden;
}

/* ── SCAN REVEAL EFFECT（ローダー退場後に起動） ── */
.effect-scan-reveal img {
  filter: blur(20px) grayscale(100%) contrast(140%);
  animation: resolveHero 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.effect-scan-reveal::after {
  content: '';
  position: absolute;
  top: -100%; left: 0; right: 0; height: 100%;
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(0, 168, 255, 0.15) 50%,
    rgba(0, 168, 255, 0.65) 100%
  );
  animation: scanDownHero 1.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes resolveHero {
  0%   { filter: blur(20px) grayscale(100%) contrast(140%); transform: scale(1.04); }
  50%  { filter: blur(5px)  grayscale(50%)  contrast(115%); }
  100% { filter: blur(0)    grayscale(0)    contrast(100%) drop-shadow(0 20px 60px rgba(0,0,0,0.08)); transform: scale(1); }
}

@keyframes scanDownHero {
  0%   { top: -100%; opacity: 1; }
  80%  { top:  110%; opacity: 1; }
  100% { top:  110%; opacity: 0; }
}

/* ── HERO ────────────────────────────── */
.hero {
  background: var(--bg);
  border-bottom: 1px solid var(--border-light);
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
  padding-top: 88px;
  padding-bottom: 88px;
  min-height: 90vh;
}

.hero__label {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--text-mid);
  margin-bottom: 1.5rem;
}

.hero__label-line {
  display: block;
  width: 24px;
  height: 1.5px;
  background: var(--accent);
}

