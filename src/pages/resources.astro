---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const resources = [
  {
    icon: "📋",
    title: "年間学習計画テンプレート",
    description: "国試までの学習スケジュールを可視化。科目ごとの進捗管理ができます。"
  },
  {
    icon: "📅",
    title: "週間スケジュール表",
    description: "1週間単位の学習計画。空きコマを有効活用できます。"
  },
  {
    icon: "📝",
    title: "科目別要点まとめ",
    description: "解剖学、生理学、運動学など各科目の重要ポイントを整理。"
  },
  {
    icon: "🃏",
    title: "暗記カードテンプレート",
    description: "繰り返し学習に最適な暗記カード。自分で追加もできます。"
  },
  {
    icon: "📊",
    title: "過去問分析シート",
    description: "頻出分野、出題傾向を可視化。効率的な対策が可能に。"
  },
  {
    icon: "📄",
    title: "実習レポートテンプレート",
    description: "症例報告、デイリーレポートなど実習で使える書式集。"
  }
];
---

<BaseLayout 
  title="学習資産ハブ"
  description="PT国試コミュニティの学習テンプレート・資料一覧。メンバー限定でCanvaから直接利用できます。"
>
  <!-- ヒーロー -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__label">Resources</p>
      <h1 class="page-hero__title">学習資産ハブ</h1>
      <p class="page-hero__subtitle">国試対策に必要なテンプレート・資料がすべて揃っています</p>
    </div>
  </section>

  <!-- 概要 -->
  <section class="section">
    <div class="container container--narrow">
      <div class="intro-block">
        <h2 class="intro-block__title">500点以上の学習資料が使い放題</h2>
        <p class="intro-block__text">
          PT国試コミュニティのメンバーは、Canvaで作成された学習テンプレートや資料にすべてアクセスできます。
          ダウンロードして印刷したり、Canva上でカスタマイズしたり、自分に合った使い方が可能です。
        </p>
      </div>
    </div>
  </section>

  <!-- 資料一覧 -->
  <section class="section section--warm">
    <div class="container">
      <div class="section__header">
        <p class="section__label">Contents</p>
        <h2 class="section__title">主な学習資料</h2>
      </div>
      <div class="resources-grid">
        {resources.map((resource) => (
          <div class="resource-card">
            <span class="resource-card__icon">{resource.icon}</span>
            <h3 class="resource-card__title">{resource.title}</h3>
            <p class="resource-card__description">{resource.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- アクセス方法 -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <div class="section__header">
        <p class="section__label">How to Access</p>
        <h2 class="section__title">アクセス方法</h2>
      </div>
      
      <div class="access-steps">
        <div class="access-step">
          <span class="access-step__number">1</span>
          <div class="access-step__content">
            <h3 class="access-step__title">コミュニティに参加</h3>
            <p class="access-step__text">無料でPT国試コミュニティのSlackに参加します</p>
          </div>
        </div>
        <div class="access-step">
          <span class="access-step__number">2</span>
          <div class="access-step__content">
            <h3 class="access-step__title">Slackで招待リンクを受け取る</h3>
            <p class="access-step__text">Slack内の資料チャンネルでCanvaへのリンクを共有しています</p>
          </div>
        </div>
        <div class="access-step">
          <span class="access-step__number">3</span>
          <div class="access-step__content">
            <h3 class="access-step__title">Canvaで資料にアクセス</h3>
            <p class="access-step__text">無料のCanvaアカウントがあれば、すべての資料を閲覧・ダウンロード・編集できます</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 注意事項 -->
  <section class="section">
    <div class="container container--narrow">
      <div class="note-block">
        <h3 class="note-block__title">ご利用上の注意</h3>
        <ul class="note-block__list">
          <li>資料はメンバー限定です。第三者への共有・再配布はご遠慮ください</li>
          <li>内容は随時更新されます。最新版はCanva上でご確認ください</li>
          <li>Canvaの無料アカウントが必要です（有料版は不要）</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-section__content">
      <h2 class="cta-section__title">今すぐ学習資産を活用しよう</h2>
      <p class="cta-section__subtitle">
        完全無料で500点以上の資料にアクセス
      </p>
      <a href="/join" class="btn btn--primary btn--lg">
        入会する
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    background: var(--gradient-hero);
    color: white;
    padding: calc(80px + var(--space-16)) 0 var(--space-16);
    text-align: center;
  }
  
  .page-hero__label {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    margin-bottom: var(--space-4);
  }
  
  .page-hero__title {
    font-size: var(--text-4xl);
    color: white;
    margin-bottom: var(--space-4);
  }
  
  .page-hero__subtitle {
    font-size: var(--text-xl);
    opacity: 0.9;
  }
  
  /* Container narrow */
  .container--narrow {
    max-width: 700px;
  }
  
  /* Intro Block */
  .intro-block {
    text-align: center;
    padding: var(--space-8);
    background: var(--color-bg-white);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
  }
  
  .intro-block__title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-4);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .intro-block__text {
    color: var(--color-text-light);
    line-height: 1.9;
  }
  
  /* Resources Grid */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  
  @media (max-width: 1024px) {
    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .resources-grid {
      grid-template-columns: 1fr;
    }
  }
  
  /* Resource Card */
  .resource-card {
    background: var(--color-bg-white);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-md);
    text-align: center;
    transition: all var(--transition-normal);
  }
  
  .resource-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-xl);
  }
  
  .resource-card__icon {
    display: block;
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }
  
  .resource-card__title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  
  .resource-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
  }
  
  /* Access Steps */
  .access-steps {
    display: grid;
    gap: var(--space-4);
  }
  
  .access-step {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-bg-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  
  .access-step__number {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    background: var(--gradient-primary);
    color: white;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-bold);
    font-family: 'Inter', sans-serif;
  }
  
  .access-step__content {
    flex: 1;
  }
  
  .access-step__title {
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
  }
  
  .access-step__text {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
  }
  
  /* Note Block */
  .note-block {
    padding: var(--space-6);
    background: var(--color-bg-alt);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--color-secondary);
  }
  
  .note-block__title {
    font-size: var(--text-base);
    margin-bottom: var(--space-3);
  }
  
  .note-block__list {
    margin: 0;
    padding-left: var(--space-5);
    color: var(--color-text-light);
    font-size: var(--text-sm);
  }
  
  .note-block__list li {
    margin-bottom: var(--space-2);
  }
</style>
