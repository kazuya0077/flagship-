---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [59,58,57,56,55,54,53,52,51,50].map(kai => ({ params: { kai: String(kai) } }));
}

const { kai } = Astro.params;
const kaiNum = Number(kai);

// 年度マッピング
const yearMap: Record<number, { year: number; passRate: number; passLine: string }> = {
  59: { year: 2024, passRate: 86.9, passLine: '一般問題・臨床実地問題を合わせた得点が166点以上（総点数200点）' },
  58: { year: 2023, passRate: 86.0, passLine: '一般問題・臨床実地問題を合わせた得点が161点以上' },
  57: { year: 2022, passRate: 86.4, passLine: '一般問題・臨床実地問題を合わせた得点が163点以上' },
  56: { year: 2021, passRate: 87.9, passLine: '一般問題・臨床実地問題を合わせた得点が163点以上' },
  55: { year: 2020, passRate: 86.6, passLine: '一般問題・臨床実地問題を合わせた得点が159点以上' },
  54: { year: 2019, passRate: 85.3, passLine: '一般問題・臨床実地問題を合わせた得点が153点以上' },
  53: { year: 2018, passRate: 80.5, passLine: '一般問題・臨床実地問題を合わせた得点が147点以上' },
  52: { year: 2017, passRate: 79.0, passLine: '一般問題・臨床実地問題を合わせた得点が149点以上' },
  51: { year: 2016, passRate: 88.5, passLine: '一般問題・臨床実地問題を合わせた得点が164点以上' },
  50: { year: 2015, passRate: 81.7, passLine: '一般問題・臨床実地問題を合わせた得点が148点以上' },
};

const info = yearMap[kaiNum];

// 出題カテゴリ別問題数（概算・実際の出題基準より）
const categoryData = [
  { label: '解剖学', general: 14, clinical: 0, color: '#00A8FF' },
  { label: '生理学', general: 12, clinical: 0, color: '#00D4B0' },
  { label: '運動学・生体力学', general: 14, clinical: 0, color: '#7C4DFF' },
  { label: '神経科学', general: 8, clinical: 0, color: '#00BCD4' },
  { label: '整形外科学', general: 16, clinical: 5, color: '#E91E63' },
  { label: '神経内科・脳外科', general: 16, clinical: 8, color: '#FF5252' },
  { label: '内科学（循環・呼吸器）', general: 12, clinical: 4, color: '#FF6D00' },
  { label: '整形・スポーツ疾患', general: 10, clinical: 6, color: '#FFC107' },
  { label: '小児・発達', general: 8, clinical: 2, color: '#8BC34A' },
  { label: '老年・介護', general: 8, clinical: 3, color: '#64B5F6' },
  { label: 'PT評価学', general: 16, clinical: 6, color: '#00A8FF' },
  { label: '運動療法', general: 14, clinical: 6, color: '#00D4B0' },
  { label: '物理療法', general: 12, clinical: 0, color: '#7C4DFF' },
];

// 過去問ソース情報
const officialSource = `https://www.mhlw.go.jp/stf/seisakunitsuite/bunya/kenkou_iryou/iryou/topics/tp230401-01_00002.html`;
---

<BaseLayout
  title={`第${kaiNum}回（${info?.year}年）PT国家試験 — FLAGSHIP`}
  description={`第${kaiNum}回理学療法士国家試験（${info?.year}年）の問題概要・合格率・合格基準・カテゴリ別出題数。`}
>

<!-- ── HEADER ── -->
<section class="yr-hero">
  <div class="yr-hero__bg" aria-hidden="true"></div>
  <div class="container yr-hero__inner">
    <a href="/kokushi" class="yr-hero__back">← 一覧に戻る</a>
    <div class="yr-hero__badge reveal">第{kaiNum}回　{info?.year}年2月実施</div>
    <h1 class="yr-hero__title reveal reveal--delay-1">
      理学療法士国家試験<br>
      <span class="yr-hero__accent">第{kaiNum}回 問題概要</span>
    </h1>
    <div class="yr-hero__meta reveal reveal--delay-2">
      <div class="yr-meta-item">
        <span class="yr-meta-item__label">合格率</span>
        <span class="yr-meta-item__val">{info?.passRate}%</span>
      </div>
      <div class="yr-meta-item">
        <span class="yr-meta-item__label">一般問題</span>
        <span class="yr-meta-item__val">160問</span>
      </div>
      <div class="yr-meta-item">
        <span class="yr-meta-item__label">臨床実地問題</span>
        <span class="yr-meta-item__val">40問</span>
      </div>
    </div>
  </div>
</section>

<!-- ── 合格基準 ── -->
<section class="section section--alt">
  <div class="container">
    <div class="passline-card reveal">
      <span class="passline-card__label">合格基準（{info?.year}年度）</span>
      <p class="passline-card__text">{info?.passLine}</p>
      <p class="passline-card__note">
        ※ 出典：厚生労働省「第{kaiNum}回理学療法士国家試験合格発表」
      </p>
    </div>
  </div>
</section>

<!-- ── カテゴリ別出題数 ── -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 出題分布</span>
      <h2 class="section-title">カテゴリ別 概算出題数</h2>
      <p class="section-sub">実際の出題数は各年度の問題を参照。下記は出題基準に基づく概算値です。</p>
    </div>
    <div class="cat-breakdown reveal">
      {categoryData.map(c => (
        <div class="cat-row">
          <div class="cat-row__label">{c.label}</div>
          <div class="cat-row__bars">
            <div class="cat-row__bar cat-row__bar--general"
                 style={`width: ${(c.general / 16) * 100}%; background: ${c.color}; opacity: 0.85`}>
              <span>{c.general}問</span>
            </div>
            {c.clinical > 0 && (
              <div class="cat-row__bar cat-row__bar--clinical"
                   style={`width: ${(c.clinical / 8) * 100}%; background: ${c.color}; opacity: 0.45`}>
                <span>+{c.clinical}問(臨床)</span>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
    <div class="legend">
      <span class="legend-item"><span class="legend-dot legend-dot--general"></span>一般問題</span>
      <span class="legend-item"><span class="legend-dot legend-dot--clinical"></span>臨床実地問題</span>
    </div>
  </div>
</section>

<!-- ── 公式問題へのリンク ── -->
<section class="section section--alt">
  <div class="container">
    <div class="official-card reveal">
      <div class="official-card__icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      </div>
      <div class="official-card__body">
        <h3 class="official-card__title">公式問題・解答はこちら</h3>
        <p class="official-card__desc">
          第{kaiNum}回の問題用紙・正答は厚生労働省の公式サイトに掲載されています。
          著作権の関係上、問題文の直接掲載は行っておりません。
        </p>
        <a
          href={officialSource}
          target="_blank" rel="noopener noreferrer"
          class="btn btn--outline"
        >
          厚生労働省 公式サイトで確認する ↗
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── 前後ナビゲーション ── -->
<section class="section yr-nav-section">
  <div class="container yr-nav">
    {kaiNum > 50 && (
      <a href={`/kokushi/${kaiNum - 1}`} class="yr-nav__btn yr-nav__btn--prev">
        ← 第{kaiNum - 1}回（{yearMap[kaiNum-1]?.year}年）
      </a>
    )}
    {kaiNum < 59 && (
      <a href={`/kokushi/${kaiNum + 1}`} class="yr-nav__btn yr-nav__btn--next">
        第{kaiNum + 1}回（{yearMap[kaiNum+1]?.year}年）→
      </a>
    )}
  </div>
</section>

</BaseLayout>

<style>
.yr-hero {
  background: #0D1B2E; position: relative; overflow: hidden;
  padding: calc(var(--nav-h) + 56px) 0 64px;
}
.yr-hero__bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 70% at 80% 40%, rgba(0,168,255,0.07) 0%, transparent 60%);
}
.yr-hero__inner { position: relative; z-index: 1; }
.yr-hero__back {
  display: inline-block; font-size: 0.82rem; color: rgba(255,255,255,0.4);
  text-decoration: none; margin-bottom: 1.5rem;
  transition: color 0.2s;
}
.yr-hero__back:hover { color: var(--accent); }
.yr-hero__badge {
  font-size: 0.78rem; font-weight: 700; letter-spacing: 0.14em;
  color: var(--accent); margin-bottom: 1rem;
}
.yr-hero__title {
  font-size: clamp(1.75rem, 5vw, 3.5rem);
  font-weight: 900; color: #fff; line-height: 1.2;
  margin-bottom: 2rem;
}
.yr-hero__accent { color: var(--accent); }
.yr-hero__meta { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.yr-meta-item__label {
  display: block; font-size: 0.72rem; font-weight: 600;
  color: rgba(255,255,255,0.35); letter-spacing: 0.1em; margin-bottom: 0.25rem;
}
.yr-meta-item__val {
  font-family: 'Inter', sans-serif; font-size: 1.5rem;
  font-weight: 900; color: #fff;
}

.passline-card {
  background: var(--bg-card); border: 1px solid var(--border-light);
  border-left: 4px solid var(--accent); padding: 2rem;
  box-shadow: var(--shadow);
}
.passline-card__label {
  display: block; font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.12em; color: var(--accent); margin-bottom: 0.75rem;
}
.passline-card__text { font-size: 1rem; color: var(--text); font-weight: 500; margin-bottom: 0.75rem; }
.passline-card__note { font-size: 0.78rem; color: var(--text-dim); }

.cat-breakdown { display: flex; flex-direction: column; gap: 0.625rem; }
.cat-row {
  display: grid; grid-template-columns: 180px 1fr; gap: 1rem; align-items: center;
}
.cat-row__label { font-size: 0.82rem; color: var(--text); white-space: nowrap; }
.cat-row__bars { display: flex; gap: 4px; align-items: center; }
.cat-row__bar {
  height: 28px; display: flex; align-items: center;
  padding: 0 0.5rem; min-width: 32px;
  transition: width 0.5s ease;
}
.cat-row__bar span { font-size: 0.68rem; font-weight: 700; color: #fff; white-space: nowrap; }
.legend {
  display: flex; gap: 1.5rem; margin-top: 1.5rem;
  font-size: 0.78rem; color: var(--text-mid);
}
.legend-dot {
  display: inline-block; width: 12px; height: 12px;
  margin-right: 0.375rem;
}
.legend-dot--general { background: var(--accent); opacity: 0.85; }
.legend-dot--clinical { background: var(--accent); opacity: 0.45; }

.official-card {
  display: flex; gap: 2rem; align-items: flex-start;
  background: var(--bg-card); border: 1px solid var(--border-light);
  padding: 2rem; box-shadow: var(--shadow);
}
.official-card__icon { color: var(--accent); flex-shrink: 0; }
.official-card__title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; }
.official-card__desc { font-size: 0.875rem; color: var(--text-body); line-height: 1.8; margin-bottom: 1.25rem; }

.yr-nav-section { padding: 2rem 0; border-top: 1px solid var(--border-light); }
.yr-nav { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
.yr-nav__btn {
  font-size: 0.875rem; font-weight: 600; color: var(--accent);
  text-decoration: none; padding: 0.625rem 1rem;
  border: 1px solid rgba(0,168,255,0.25);
  transition: all 0.2s;
}
.yr-nav__btn:hover { background: var(--accent-dim); }

@media (max-width: 640px) {
  .cat-row { grid-template-columns: 1fr; }
  .official-card { flex-direction: column; }
}
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.05 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
