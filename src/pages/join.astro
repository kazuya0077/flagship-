---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="無料で参加する — FLAGSHIP"
  description="FLAGSHIPは完全無料のPT学生コミュニティです。Slackに参加して、仲間と一緒に国試対策・キャリア設計を進めましょう。"
>

<!-- ── PAGE HERO ── -->
<section class="join-hero">
  <div class="join-hero__bg" aria-hidden="true"></div>
  <div class="container join-hero__inner">
    <div class="join-hero__label reveal">
      <span class="join-hero__label-line"></span>
      完全無料
    </div>
    <h1 class="join-hero__title reveal reveal--delay-1">
      今日から、<br>
      <span class="join-hero__accent">仲間と学ぶ</span>環境へ。
    </h1>
    <p class="join-hero__desc reveal reveal--delay-2">
      登録費・月額費・一切なし。<br>
      PT学生であれば、学年・地域を問わずどなたでも参加できます。
    </p>
  </div>
</section>

<!-- ── FREE BADGE ── -->
<section class="section free-section">
  <div class="container">
    <div class="free-card reveal">
      <div class="free-card__left">
        <div class="free-card__price">
          <span class="free-card__label">参加費用</span>
          <span class="free-card__amount">完全無料</span>
          <span class="free-card__note">Forever Free — ずっと無料</span>
        </div>
      </div>
      <div class="free-card__right">
        <ul class="free-card__list">
          {[
            'Slackコミュニティへのフルアクセス',
            '国試Q&Aデータベース（順次追加）',
            '学習テンプレート・まとめ資料',
            '先輩PTへの質問・相談環境',
            '月次オンライン勉強会・交流イベント',
            '実習・就職サポート情報',
          ].map(item => (
            <li class="free-card__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ── JOIN FLOW ── -->
<section class="section section--alt" id="flow">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">— 参加の流れ</span>
      <h2 class="section-title">3ステップで参加完了</h2>
      <p class="section-sub">アカウント登録・支払いは不要。今すぐSlackに参加できます。</p>
    </div>

    <div class="flow-steps reveal">
      {[
        {
          num: '01',
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 2H3v16h5l3 3 3-3h7V2z"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="14" y2="12"/></svg>`,
          title: '招待リンクをタップ',
          desc: '下のボタンからSlack招待リンクにアクセスします。',
        },
        {
          num: '02',
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
          title: 'アカウント作成またはログイン',
          desc: 'Slackアカウントをお持ちでない方は無料で作成。すでにある方はそのままログイン。',
        },
        {
          num: '03',
          icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
          title: 'コミュニティに参加！',
          desc: '自己紹介チャンネルで挨拶して、さっそく仲間と交流を始めましょう。',
        },
      ].map((step, i) => (
        <div class={`flow-step reveal${i > 0 ? ' reveal--delay-' + i : ''}`}>
          <div class="flow-step__num">{step.num}</div>
          <div class="flow-step__icon" set:html={step.icon}></div>
          <h3 class="flow-step__title">{step.title}</h3>
          <p class="flow-step__desc">{step.desc}</p>
        </div>
      ))}
    </div>

    <div class="flow-cta reveal">
      <a
        href="https://join.slack.com/t/flagship-0169/shared_invite/zt-3rx8j8dfp-f7KBi5eKMllznjjQFm4BnQ"
        target="_blank" rel="noopener noreferrer"
        class="btn btn--primary btn--lg flow-cta__btn"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 2H3v16h5l3 3 3-3h7V2z"/></svg>
        Slackで無料参加する
      </a>
      <p class="flow-cta__note">
        登録費用なし　｜　メールアドレス不要　｜　いつでも退会可能
      </p>
    </div>
  </div>
</section>

<!-- ── FAQ ── -->
<section class="section">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="section-label">— よくある質問</span>
      <h2 class="section-title">参加に関するQ&A</h2>
    </div>

    <div class="faq-list">
      {[
        {
          q: '本当に無料ですか？',
          a: 'はい、完全無料です。参加費・月額費・登録費などは一切ありません。PT学生であれば誰でも無料で参加・利用できます。このコミュニティは推奨教材のアフィリエイト収益（ASP）によって運営されています。',
        },
        {
          q: '推奨教材を必ず買わないといけませんか？',
          a: 'いいえ、購入は完全に任意です。コミュニティの参加・利用はすべて無料で、教材の購入を強制することは一切ありません。',
        },
        {
          q: 'どんな学生でも参加できますか？',
          a: '大学・専門学校を問わず、PT（理学療法士）を目指すすべての学生が対象です。学年・地域も不問です。',
        },
        {
          q: 'Slackを使ったことがありません',
          a: '参加後にスタートガイドをお渡しします。スマホアプリでLINEのように直感的に使えます。',
        },
        {
          q: '退会はどうすればいいですか？',
          a: 'Slackのワークスペースを退出するだけです。手続きや連絡は不要で、いつでも自由に退会できます。',
        },
      ].map((item, i) => (
        <details class={`faq-item reveal${i > 0 ? ' reveal--delay-' + (i % 3) : ''}`}>
          <summary class="faq-item__q">
            <span class="faq-item__q-mark">Q</span>
            {item.q}
            <svg class="faq-item__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-item__a">
            <span class="faq-item__a-mark">A</span>
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* ── JOIN HERO ── */
.join-hero {
  background: var(--bg);
  position: relative; overflow: hidden;
  padding-top: calc(var(--nav-h) + 64px);
  padding-bottom: 64px;
  border-bottom: 1px solid var(--border-light);
}
.join-hero__bg {
  position: absolute; inset: 0; pointer-events: none;
  background-image: radial-gradient(circle, rgba(43,58,85,0.06) 1px, transparent 1px);
  background-size: 24px 24px;
}
.join-hero__inner { position: relative; z-index: 1; }
.join-hero__label {
  display: inline-flex; align-items: center; gap: 0.75rem;
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.18em; color: var(--text-mid);
  margin-bottom: 1.5rem;
}
.join-hero__label-line {
  display: block; width: 28px; height: 1.5px;
  background: var(--accent);
}
.join-hero__title {
  font-size: clamp(2rem, 5.5vw, 3.8rem);
  font-weight: 900; line-height: 1.2;
  letter-spacing: -0.02em; color: var(--text);
  margin-bottom: 1.5rem;
}
.join-hero__accent { color: var(--accent); }
.join-hero__desc {
  font-size: clamp(0.9rem, 2.5vw, 1.05rem);
  color: var(--text-body); line-height: 2; max-width: 480px;
}

/* ── FREE CARD ── */
.free-section { background: var(--bg); }
.free-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 3rem;
  align-items: center;
  background: var(--bg-dark);
  padding: 3rem;
  position: relative; overflow: hidden;
}
.free-card::before {
  content: ''; position: absolute;
  top: -30%; right: -10%; width: 50%; height: 160%;
  background: radial-gradient(ellipse, rgba(0,168,255,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.free-card__price { text-align: center; }
.free-card__label {
  display: block; font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.14em; color: var(--accent);
  margin-bottom: 0.75rem;
}
.free-card__amount {
  display: block; font-family: 'Inter', sans-serif;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 900; color: #fff;
  letter-spacing: -0.02em; line-height: 1;
  margin-bottom: 0.5rem;
}
.free-card__note {
  font-size: 0.75rem; color: rgba(255,255,255,0.35);
  letter-spacing: 0.06em; white-space: nowrap;
}
.free-card__list {
  list-style: none; display: grid;
  grid-template-columns: repeat(2, 1fr); gap: 0.875rem 2rem;
}
.free-card__item {
  display: flex; align-items: center; gap: 0.625rem;
  font-size: 0.875rem; color: rgba(255,255,255,0.8);
}
.free-card__item svg { flex-shrink: 0; color: var(--accent); }

/* ── FLOW STEPS ── */
.flow-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem; margin-bottom: 3.5rem;
  position: relative;
}
.flow-steps::before {
  content: '';
  position: absolute;
  top: 2.5rem; left: calc(33.33% - 0.5rem); right: calc(33.33% - 0.5rem);
  height: 1.5px;
  background: var(--border-light);
  pointer-events: none;
}
.flow-step {
  text-align: center; padding: 2rem 1.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow);
  position: relative;
  transition: box-shadow 0.3s var(--ease), transform 0.3s var(--ease);
}
.flow-step:hover {
  box-shadow: var(--shadow-md); transform: translateY(-2px);
}
.flow-step__num {
  font-family: 'Inter', sans-serif; font-size: 3rem;
  font-weight: 900; color: var(--accent); opacity: 0.15;
  line-height: 1; margin-bottom: 0.5rem;
}
.flow-step__icon {
  width: 48px; height: 48px;
  background: var(--accent-dim); border: 1px solid rgba(0,168,255,0.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent); margin: 0 auto 1rem;
}
.flow-step__title {
  font-size: 0.95rem; font-weight: 700;
  color: var(--text); margin-bottom: 0.625rem;
}
.flow-step__desc {
  font-size: 0.825rem; color: var(--text-body);
  line-height: 1.7;
}

/* ── FLOW CTA ── */
.flow-cta {
  text-align: center; display: flex;
  flex-direction: column; align-items: center; gap: 1rem;
}
.flow-cta__btn {
  display: inline-flex; align-items: center; gap: 0.625rem;
}
.flow-cta__note {
  font-size: 0.78rem; color: var(--text-dim);
  letter-spacing: 0.04em;
}

/* ── FAQ ── */
.faq-list {
  max-width: 720px; margin: 0 auto;
  display: flex; flex-direction: column; gap: 0;
  border-top: 1px solid var(--border-light);
}
.faq-item {
  border-bottom: 1px solid var(--border-light);
}
.faq-item__q {
  display: flex; align-items: center; gap: 1rem;
  padding: 1.25rem 0; cursor: pointer;
  font-size: 0.95rem; font-weight: 600;
  color: var(--text); list-style: none;
  transition: color 0.2s;
}
.faq-item__q::-webkit-details-marker { display: none; }
.faq-item__q:hover { color: var(--accent); }
.faq-item__q-mark {
  flex-shrink: 0; width: 28px; height: 28px;
  background: var(--accent-dim); color: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.78rem; font-weight: 800;
  letter-spacing: 0.04em;
}
.faq-item__chevron {
  margin-left: auto; flex-shrink: 0;
  transition: transform 0.25s var(--ease);
  color: var(--text-dim);
}
details[open] .faq-item__chevron { transform: rotate(180deg); }
.faq-item__a {
  display: flex; gap: 1rem;
  padding: 0 0 1.5rem;
}
.faq-item__a-mark {
  flex-shrink: 0; width: 28px; height: 28px;
  background: var(--bg-alt); color: var(--text-mid);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.78rem; font-weight: 800;
}
.faq-item__a p {
  font-size: 0.9rem; color: var(--text-body); line-height: 1.85;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .free-card {
    grid-template-columns: 1fr;
    gap: 2rem; padding: 2rem 1.5rem;
    text-align: center;
  }
  .free-card__list {
    grid-template-columns: 1fr;
    text-align: left;
  }
  .flow-steps {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .flow-steps::before { display: none; }
}

@media (max-width: 640px) {
  .join-hero { padding-top: calc(var(--nav-h) + 40px); padding-bottom: 40px; }
  .join-hero__title { font-size: clamp(1.75rem, 9vw, 2.5rem); }
  .flow-step { padding: 1.5rem 1.25rem; }
  .faq-item__q { font-size: 0.88rem; }
  .faq-item__a p { font-size: 0.85rem; }
}
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.05 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
