---
interface Props {
  title: string;
  description?: string;
  price?: string;
  badge?: string;        // e.g. "おすすめ", "定番"
  links: {
    amazon?: string;
    rakuten?: string;
    yahoo?: string;
    official?: string;
  };
  image?: string;
}

const { title, description, price, badge, links, image } = Astro.props;
---

<div class="asp-card target-card reveal">
  <span class="ad-label">PR</span>

  {image ? (
    <div class="asp-card__img-wrap">
      <img src={image} alt={title} loading="lazy" class="asp-card__img" />
    </div>
  ) : (
    <div class="asp-card__img-wrap asp-card__img-wrap--placeholder">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-dim)" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
    </div>
  )}

  <div class="asp-card__body">
    {badge && <span class="asp-card__badge">{badge}</span>}
    <h3 class="asp-card__title">{title}</h3>
    {description && <p class="asp-card__desc">{description}</p>}
    {price && <p class="asp-card__price">{price}</p>}

    <div class="asp-btn-group">
      {links.official && (
        <a href={links.official} target="_blank" rel="noopener noreferrer sponsored"
           class="asp-btn asp-btn--official">公式サイト</a>
      )}
      {links.amazon && (
        <a href={links.amazon} target="_blank" rel="noopener noreferrer sponsored"
           class="asp-btn asp-btn--amazon">Amazon</a>
      )}
      {links.rakuten && (
        <a href={links.rakuten} target="_blank" rel="noopener noreferrer sponsored"
           class="asp-btn asp-btn--rakuten">楽天</a>
      )}
      {links.yahoo && (
        <a href={links.yahoo} target="_blank" rel="noopener noreferrer sponsored"
           class="asp-btn asp-btn--yahoo">Yahoo!</a>
      )}
    </div>
  </div>
</div>

<style>
.asp-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  transition: box-shadow 0.3s, transform 0.3s;
  display: flex;
  flex-direction: column;
}

.asp-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}

.asp-card__img-wrap {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--bg-alt);
}

.asp-card__img-wrap--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.asp-card__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 1rem;
}

.asp-card__body {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.asp-card__badge {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  background: var(--accent);
  color: #fff;
  padding: 0.1rem 0.5rem;
  margin-bottom: 0.5rem;
}

.asp-card__title {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.5rem;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.asp-card__desc {
  font-size: 0.8rem;
  color: var(--text-mid);
  line-height: 1.6;
  margin-bottom: 0.75rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}

.asp-card__price {
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 1rem;
}

.asp-btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: auto;
}

.asp-btn {
  flex: 1;
  min-width: 72px;
  padding: 0.45rem 0.5rem;
  text-align: center;
  font-size: 0.72rem;
  font-weight: 700;
  color: #fff;
  text-decoration: none;
  transition: opacity 0.2s, transform 0.2s;
  letter-spacing: 0.04em;
}

.asp-btn:hover {
  opacity: 0.85;
  transform: translateY(-1px);
}

.asp-btn--official { background: var(--accent); }
.asp-btn--amazon   { background: #FF9900; }
.asp-btn--rakuten  { background: #BF0000; }
.asp-btn--yahoo    { background: #FF0033; }
</style>
