---
const nav = [
  { href: '/',          label: 'Home' },
  { href: '/blog',      label: 'Blog' },
  { href: '/resources', label: '学習素材' },
  { href: '/about',     label: 'About' },
  { href: '/faq',       label: 'FAQ' },
];
---

<header class="nav" id="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">FLAG<span>SHIP</span></a>

    <nav class="nav__links" aria-label="グローバルナビ">
      {nav.map(link => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </nav>

    <a href="/#join" class="btn btn--primary nav__cta">無料で参加</a>

    <button class="nav__burger" id="navBurger" aria-label="メニューを開く" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile overlay -->
  <nav class="nav__mobile" id="navMobile" aria-label="モバイルナビ">
    {nav.map(link => (
      <a href={link.href} class="nav__link">{link.label}</a>
    ))}
    <a href="/#join" class="btn btn--primary" style="margin-top: 0.75rem; justify-content: center;">
      無料で参加
    </a>
  </nav>
</header>

<script>
  const burger  = document.getElementById('navBurger');
  const mobile  = document.getElementById('navMobile');
  const navEl   = document.getElementById('nav');

  burger?.addEventListener('click', () => {
    const open = mobile?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
  });

  mobile?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobile.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });

  const onScroll = () => navEl?.classList.toggle('scrolled', window.scrollY > 10);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
